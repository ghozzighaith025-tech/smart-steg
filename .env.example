# GridDNA AI — Environment Configuration
# Copy to .env and adjust values

# PostgreSQL / TimescaleDB
POSTGRES_USER=griddna
POSTGRES_PASSWORD=griddna_dev_secret
POSTGRES_DB=griddna
DATABASE_URL=postgresql://griddna:griddna_dev_secret@localhost:5432/griddna

# Redis
REDIS_URL=redis://localhost:6379

# MQTT (EMQX)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_BROKER_URL_TLS=mqtts://localhost:8883
MQTT_USERNAME=griddna_backend
MQTT_PASSWORD=mqtt_dev_secret

# Backend API
API_PORT=3000
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRES_IN=7d

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_PORT=8000

# Frontend
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
